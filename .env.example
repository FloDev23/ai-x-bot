# ========== X (Twitter) API Keys ==========
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_token_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# ========== Groq API ==========
GROQ_API_KEY=your_groq_api_key_here
# Modello Groq da usare (mixtral-8x7b-32768 è deprecato, non usarlo più)
GROQ_MODEL=openai/gpt-oss-120b

# ========== NewsAPI ==========
NEWSAPI_KEY=your_newsapi_key_here

# ========== Bot Configuration (v1, mantenute) ==========
# NOTA: topic in inglese, mercato internazionale (fuori Italia)
SEARCH_TOPICS=CrossFit,functional training,yoga,pilates,HIIT,calisthenics,boutique fitness,gym management software,drop-in fitness,class booking app,boxing gym,indoor cycling,gym owner,fitness franchise,wellness trend,gym membership retention,fitness studio marketing
POST_INTERVAL=3600
MAX_SEARCH_RESULTS=5
ENGAGEMENT_CHECK_INTERVAL=1800
LIKE_ENGAGEMENT_THRESHOLD=50
MAX_COMMENTS_PER_SESSION=3

# ========== Growth Agent v3: orari dei cicli ==========
# NOTA: da febbraio 2026 l'API X è pay-per-use (letture ~$0.005, post ~$0.015,
# post con link ~$0.20). Questi orari sono pensati per contenere i costi:
# 3 post/giorno, 2 ricerche lead/giorno, 2 cicli di engagement mirato/giorno.
DAILY_POST_TIMES=09:00,14:00,19:00
OPPORTUNITY_CYCLE_TIMES=10:00,16:00
TARGETED_ENGAGEMENT_TIMES=11:00,18:00
PERFORMANCE_CYCLE_TIME=23:00
BUILD_IN_PUBLIC_DAY=friday

# ========== Scoring tweet (0-40, soglia consigliata 24 = 60%) ==========
TWEET_SCORE_THRESHOLD=24
MAX_REGENERATION_ATTEMPTS=2

# ========== Anti-spam ==========
MAX_FLEXDROPIN_MENTIONS_PER_DAY=2
MAX_LINKS_PER_WEEK=3
USER_COMMENT_COOLDOWN_HOURS=24

# ========== Account target curati (punto 7) ==========
# Username X separati da virgola, SENZA @ (gestori palestre/boutique studio,
# coach, founder fitness-tech FUORI DALL'ITALIA - mercato US/UK/EU)
# NOTA: lista di partenza da classifiche pubbliche, verifica tu stesso che
# siano ancora attivi prima di lasciarla in produzione. Skew verso
# creator/coach più che gestori palestra puri: integra con ricerche manuali
# mirate (es. "which gym software", "boutique fitness owner") per trovare
# lead commerciali con follower più bassi ma più in target.
TARGET_ACCOUNTS=SteDobie,thejoeyswoll,SteveKamb,ChamberofFit,chrisjonmeyer,FamManFitness,321gaux,feelthebyrn1,itscoachgoodman

# ========== Human mode ==========
# Probabilità (0-1) di pubblicare un post informale invece che da palinsesto
HUMAN_MODE_PROBABILITY=0.15

# ========== Debug mode ==========
DEBUG=False
